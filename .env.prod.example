# CLIFF — production .env template (for docker-compose.prod.yml)
#
# On the VPS:  cp .env.prod.example .env  &&  edit .env  &&  docker compose -f docker-compose.prod.yml up -d
#
# Only secrets / provider config live here. REDIS_URL, CORS_ORIGINS, ENVIRONMENT
# are set by docker-compose.prod.yml and must NOT be overridden here.
# NEVER commit the real .env (it is gitignored).

# ── NASA ─────────────────────────────────────────────────────────────────
# DEMO_KEY works out of the box (rate-limited). Get a free key: https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# ── AI (OpenAI-compatible). Leave AI_API_KEY empty to disable /ai/* (returns 503). ─
AI_BASE_URL=https://api.openai.com
AI_API_KEY=
AI_MODEL=meta/llama-4-maverick-instruct

# ── Text-to-speech (optional). Leave empty to disable narration. ─
TTS_API_KEY=
TTS_BASE_URL=
TTS_MODEL=elevenlabs-multilingual-v2
TTS_DEFAULT_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2

# ── NASA FIRMS (fire/thermal layer for the live Earth globe), optional ─
FIRMS_API_KEY=

# ── Autonomous scheduler tuning (optional; safe defaults shown) ─
INGEST_INTERVAL_SECONDS=1800
RISK_REFRESH_SECONDS=3600
WATCHLIST_SIZE=30
