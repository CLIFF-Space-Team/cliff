# CLIFF Backend — environment template
# Copy to .env and fill in real values. Never commit .env.

ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# NASA — get a real key at https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# OpenAI-compatible AI provider
AI_BASE_URL=https://api.openai.com
AI_API_KEY=
AI_MODEL=meta/llama-4-maverick-instruct

# Text-to-speech service (optional). Leave empty to disable narration.
# TTS_BASE_URL must be the upstream HTTPS endpoint that speaks the
# submit-and-poll task protocol. TTS_API_KEY is sent as a Bearer token.
TTS_API_KEY=
TTS_BASE_URL=
TTS_MODEL=elevenlabs-multilingual-v2
TTS_DEFAULT_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2

# Redis (autonomous risk pipeline cache)
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Autonomous scheduler tuning
INGEST_INTERVAL_SECONDS=1800
RISK_REFRESH_SECONDS=3600
WATCHLIST_SIZE=30

# Logging
LOG_LEVEL=info
